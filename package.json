{
  "name": "oura-pix",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered cross-border e-commerce product detail page generator",
  "scripts": {
    "dev": "next dev -p 4001",
    "dev:check": "npm run setup && npm run db:migrate && npm run dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "wrangler deploy",
    "deploy": "npm run build:cf && npm run predeploy && wrangler pages deploy",
    "deploy:prod": "npm run build:cf && npm run predeploy && wrangler pages deploy --env production",
    "preview": "npm run build:cf && wrangler pages dev .open-next/worker.js",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "setup": "bash scripts/setup-dev.sh",
    "predeploy": "bash scripts/pre-deploy.sh",
    "postinstall": "patch-package",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:init": "bash scripts/init-cloudflare.sh",
    "cf:check": "bash scripts/check-cloudflare.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply oura-pix-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply oura-pix-db",
    "db:studio": "drizzle-kit studio",
    "db:check": "bash scripts/check-db.sh"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.0.0",
    "@auth/drizzle-adapter": "^1.7.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@stripe/stripe-js": "^4.9.0",
    "ai": "^4.0.0",
    "better-auth": "1.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.460.0",
    "next": "^15.5.10",
    "next-intl": "^3.25.0",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.0",
    "react-hook-form": "^7.53.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.0.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.18",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "wrangler": "^4.69.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
