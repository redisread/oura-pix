# ============================================
# OuraPix Environment Configuration
# ============================================
#
# 使用说明:
# 1. 复制此文件为 .env.local: cp .env.example .env.local
# 2. 生成 AUTH_SECRET: openssl rand -base64 32
# 3. 配置第三方服务密钥（见下方链接）
# 4. 运行 npm run dev 启动开发服务器
#
# 注意: .env.local 不会被提交到 Git
# ============================================

# ============================================
# 应用配置
# ============================================
# 开发服务器端口（与 package.json 的 dev 命令一致）
NEXT_PUBLIC_APP_URL=http://localhost:4001
NODE_ENV=development

# ============================================
# 认证（Better Auth）
# ============================================
# 必需: 使用 openssl rand -base64 32 生成
AUTH_SECRET=

# OAuth 提供商（可选）
# Google OAuth: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ============================================
# 支付（Stripe）
# ============================================
# 获取密钥: https://dashboard.stripe.com/apikeys
# 客户端公钥（可在浏览器中使用）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# 服务端密钥（仅服务器端使用，切勿暴露）
STRIPE_SECRET_KEY=sk_test_

# Webhook 密钥: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe 价格 ID（从 Stripe Dashboard 获取）
# 订阅套餐
STRIPE_STARTER_PRICE_ID=price_
STRIPE_PRO_PRICE_ID=price_
STRIPE_ENTERPRISE_PRICE_ID=price_

# 积分充值
STRIPE_CREDITS_SMALL_PRICE_ID=price_
STRIPE_CREDITS_MEDIUM_PRICE_ID=price_
STRIPE_CREDITS_LARGE_PRICE_ID=price_

# ============================================
# 邮件发送（Resend）
# ============================================
# 获取 API Key: https://resend.com/api-keys
RESEND_API_KEY=re_
FROM_EMAIL=noreply@ourapix.jiahongw.com
FROM_NAME=OuraPix

# ============================================
# AI 生成（Google Gemini）
# ============================================
# 获取 API Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ============================================
# Cloudflare（本地开发）
# ============================================
# D1 数据库和 R2 存储通过 wrangler 自动配置
# 本地开发时无需配置这些变量

# R2 公开访问 URL（可选，本地开发可使用 localhost）
CLOUDFLARE_R2_PUBLIC_URL=http://localhost:8787

# ============================================
# 可选: 分析与监控
# ============================================
# PostHog 分析
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry 错误追踪
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# 可选: 速率限制
# ============================================
# Upstash Redis（用于 API 速率限制）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
