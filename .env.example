# ============================================
# OuraPix Environment Configuration
# Copy this file to .env.local for local development
# ============================================

# ============================================
# Application Configuration
# ============================================
PORT=4001
NEXT_PUBLIC_APP_URL=http://localhost:4001
NODE_ENV=development

# ============================================
# Better Auth Configuration
# ============================================
# Generate a secure random string for AUTH_SECRET
# You can use: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-key-here
AUTH_URL=http://localhost:4001

# ============================================
# OAuth Providers (Optional)
# ============================================
# Google OAuth
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# GitHub OAuth
AUTH_GITHUB_ID=your-github-oauth-client-id
AUTH_GITHUB_SECRET=your-github-oauth-client-secret

# ============================================
# Cloudflare Configuration
# ============================================
# D1 Database Binding (used in production)
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id

# R2 Storage
CLOUDFLARE_R2_BUCKET_NAME=oura-pix-images
CLOUDFLARE_R2_ACCOUNT_ID=your-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key

# ============================================
# AI Configuration
# ============================================
# Google Gemini API Key for image generation
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# Stripe Configuration
# ============================================
# Stripe Publishable Key (public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Secret Key (server-side only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Webhook Secret (for webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# Optional: Analytics & Monitoring
# ============================================
# PostHog (optional)
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (optional)
# SENTRY_DSN=your-sentry-dsn
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# ============================================
# Optional: Rate Limiting
# ============================================
# Upstash Redis for rate limiting (optional)
# UPSTASH_REDIS_REST_URL=your-upstash-url
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
