# Local Development Environment Variables
# Copy this file to .env.local for local development

# App URL
PORT=4001
NEXT_PUBLIC_APP_URL=http://localhost:4001

# Better Auth Secret (generate a random string for local dev)
AUTH_SECRET=your-local-auth-secret-change-in-production

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# R2 Public URL (optional - for generating public URLs)
# If not set, R2 keys will be used as identifiers
CLOUDFLARE_R2_PUBLIC_URL=

# Note: D1 and R2 bindings are configured in wrangler.toml
# and accessed through getCloudflareContext() in local dev